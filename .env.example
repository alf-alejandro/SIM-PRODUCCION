# ─── Credenciales Polymarket (REQUERIDAS) ────────────────────────────────────
POLYMARKET_KEY=0xtuprivatekey...
PROXY_ADDRESS=0xtuproxyaddress...

# ─── Red ─────────────────────────────────────────────────────────────────────
POLY_CHAIN_ID=137

# ─── Capital y tamaño de entrada ─────────────────────────────────────────────
